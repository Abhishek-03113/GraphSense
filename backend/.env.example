# PostgreSQL DSN configuration
# Replace user, password, host, port, dbname with your local database values.
DATABASE_DSN="postgresql+asyncpg://user:password@localhost:5432/dbname"

# Database Connection Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# Google Gemini API key for LLM-powered chat (free tier: https://ai.google.dev)
GEMINI_API_KEY="AIzaSyDeBXZLK1Le3a46djqnoQP_zoCWE373SRc"

# Gemini embedding model (768-dimensional vectors)
GEMINI_EMBEDDING_MODEL="text-embedding-001"
